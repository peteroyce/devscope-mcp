# GitHub Personal Access Token
# Create one at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user
GITHUB_TOKEN=ghp_your_token_here

# Default GitHub organisation (optional)
# When set, tools that accept an `org` parameter will use this as the default.
# Example: GITHUB_DEFAULT_ORG=my-org-name
GITHUB_DEFAULT_ORG=
